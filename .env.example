# ─────────────────────────────────────────────────────────────
# .env.example — bmad-encar-demo 환경변수 견본 (값 없이 키만 문서화)
#
# 이 파일은 "어떤 환경변수가 필요한지" 알려주는 견본입니다(git에 올림, 비밀값 없음).
# 실제 값은 각 앱 폴더의 .env 파일에 넣으며, 그 파일들은 .gitignore로 보호됩니다.
#
# ⚠️ 배치 규칙
#   - web/.env.local  → 브라우저로 전달되는 값만. 반드시 NEXT_PUBLIC_ 접두사.
#   - api/.env        → 서버 전용. Gemini 키는 여기에만! (웹에 절대 넣지 않음)
#   - app/.env        → Flutter 앱(Epic 7, 나중)
#   anon key는 RLS가 보호하므로 클라이언트 노출 안전. service_role 키는 사용하지 않음.
# ─────────────────────────────────────────────────────────────

# ===== web/.env.local (사용자·관리자 웹 / Next.js) =====
# 브라우저로 전달되어야 하므로 NEXT_PUBLIC_ 접두사 필수
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===== api/.env (AI 백엔드 / FastAPI + LangGraph) =====
# 서버 전용 — 외부로 노출되지 않음
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Gemini API 키 — ⚠️ 오직 여기(api)에만 둔다. 웹에는 넣지 않는다.
GEMINI_API_KEY=
# 임베딩 차원 — pgvector vector(768)과 반드시 일치 (불일치 시 AI 검색 미동작)
GEMINI_EMBEDDING_DIM=768
# 모델 ID (아키텍처 확정값)
GEMINI_GENERATION_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ===== app/.env (Flutter 모바일 앱 / Epic 7, 나중에 사용) =====
# SUPABASE_URL / SUPABASE_ANON_KEY 는 위와 동일한 값 사용
# API_BASE_URL 은 FastAPI(api) 서버 주소 (예: http://10.0.2.2:8000 — 안드로이드 에뮬레이터)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# API_BASE_URL=
