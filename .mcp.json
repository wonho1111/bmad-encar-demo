{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=psrnsasxpkpwqdukjdmt"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.76", "--browser", "chromium", "--no-sandbox"]
    },
    "mobile": {
      "command": "npx",
      "args": ["-y", "@mobilenext/mobile-mcp@0.0.60"],
      "env": {
        "ANDROID_HOME": "${ANDROID_HOME}",
        "ANDROID_SDK_ROOT": "${ANDROID_HOME}"
      }
    }
  }
}