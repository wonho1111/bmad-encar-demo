# api/.env.example — AI 백엔드 전용 환경변수 견본 (값 없이 키만 문서화)
# 실제 값은 api/.env 에 넣는다(.gitignore로 보호). 루트 .env.example의 api 섹션과 동일하게 유지.

# ── Supabase ── JWT 검증(auth.get_user)에 사용. web/.env.local과 같은 프로젝트 값.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── 읽기전용 DB 직결 ── 대시보드 > Connect > "Transaction pooler" 문자열을 그대로 사용.
#   형식: postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   ⚠️ 포트 6543(Transaction)인지 확인(AC-DB-1, Story 8.4). readonly.py가 매 쿼리를
#   BEGIN;SET LOCAL ROLE ai_readonly;...;COMMIT; 으로 감싸 트랜잭션 스코프로 격리하므로,
#   커넥션 풀이 재사용하는 트랜잭션 풀러(6543)에서만 안전하다. 5432(Session)는 더 이상 쓰지 않는다.
DATABASE_URL=

# ── Gemini ── 4.2(임베딩)·4.3+(LLM)에서 사용. 4.1에서는 미사용(키 비워도 기동됨).
GEMINI_API_KEY=
GEMINI_EMBEDDING_DIM=768
# 명시 버전 고정 권장(별칭 *-latest는 자동으로 최신·고가 모델로 흐를 수 있음). 데모 기준 후보: gemini-3.1-flash-lite(권장)·gemini-2.5-flash-lite(최저가)
GEMINI_GENERATION_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── CORS 허용 오리진(웹) ──
#   CORS_ORIGINS: 정확히 일치할 오리진(쉼표 구분). 운영 도메인·localhost 등.
#   CORS_ORIGIN_REGEX(선택): preview처럼 매번 바뀌는 오리진을 정규식으로 허용. 개발 서버용.
#     예) ^https://bmad-encar-demo-.*\.vercel\.app$   (미설정이면 정확 매칭만 사용)
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=
