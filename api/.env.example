# api/.env.example — AI 백엔드 전용 환경변수 견본 (값 없이 키만 문서화)
# 실제 값은 api/.env 에 넣는다(.gitignore로 보호). 루트 .env.example의 api 섹션과 동일하게 유지.

# ── Supabase ── JWT 검증(auth.get_user)에 사용. web/.env.local과 같은 프로젝트 값.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── 읽기전용 DB 직결 ── 대시보드 > Connect > "Session pooler" 문자열을 그대로 사용.
#   형식: postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   ⚠️ 포트 5432(Session)인지 확인. 6543(Transaction)은 SET ROLE이 풀려 읽기전용 보장이 깨지므로 사용 금지.
DATABASE_URL=

# ── Gemini ── 4.2(임베딩)·4.3+(LLM)에서 사용. 4.1에서는 미사용(키 비워도 기동됨).
GEMINI_API_KEY=
GEMINI_EMBEDDING_DIM=768
GEMINI_GENERATION_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── 개발 서버 CORS 허용 오리진(웹). 쉼표 구분. ──
CORS_ORIGINS=http://localhost:3000
